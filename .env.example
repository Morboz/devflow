# Copy to .env and fill in real values. .env is gitignored.

# --- Database (ADR-0013: PostgreSQL) ---
# Set a real password; use the SAME value for POSTGRES_PASSWORD (read by
# docker compose) and inside the DATABASE_URL strings (read by the app).
POSTGRES_PASSWORD=<set-a-real-password>
DATABASE_URL=postgres://devflow:<same-password>@localhost:5433/devflow
DATABASE_URL_TEST=postgres://devflow:<same-password>@localhost:5433/devflow_test
# Admin connection (to the maintenance DB) used to create the test DB.
DATABASE_URL_ADMIN=postgres://devflow:<same-password>@localhost:5433/postgres

# --- Target repo (single-tenant MVP) ---
DEVFLOW_REPO_OWNER=Morboz
DEVFLOW_REPO_NAME=devflow

# --- GitHub App (ADR-0008: minimal permissions) ---
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=              # PEM contents (multi-line, quoted)
GITHUB_INSTALLATION_ID=
GITHUB_WEBHOOK_SECRET=           # verifies X-Hub-Signature-256 (D2)

# --- Execution Engine provider config (ADR-0009; used by D8) ---
DEVFLOW_PROVIDER_MODEL=
DEVFLOW_PROVIDER_API_KEY=        # passed to Claude Code as ANTHROPIC_API_KEY

# --- Runtime knobs (all optional, defaults shown) ---
# PORT=3000
# DEVFLOW_LEASE_SECONDS=1800      # worker lease before a stuck job is failed
# DEVFLOW_POLL_MS=1000            # worker idle poll interval
# DEVFLOW_GC_INTERVAL_MS=3600000  # orphan-GC sweep interval
